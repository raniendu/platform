# Copy to .env for direct app development. Do not commit populated secrets.

# Model provider. "ollama" for local dev; "digitalocean" for prod.
# RAMAN_MODEL_PROVIDER=ollama

# Model identifier. Provider-dependent:
#   ollama       -> an Ollama tag, e.g. gemma4:26b, qwen3
#   digitalocean -> a DO catalog id, e.g. gemma-4-31B-it
RAMAN_DEV_MODEL=gemma4:26b

# Ollama local development.
OLLAMA_BASE_URL=http://localhost:11434/v1

# DigitalOcean Serverless Inference.
# Required when RAMAN_MODEL_PROVIDER=digitalocean.
# DO_INFERENCE_API_KEY=
# DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1

# Agent selection.
# RAMAN_AGENT=raman
# RAMAN_SPEC_ROOT=/abs/path/to/spec
# RAMAN_LOG_LEVEL=INFO
# RAMAN_OBSERVABILITY_ENABLED=false
# RAMAN_OBSERVABILITY_SERVICE_NAME=raman
# RAMAN_OTLP_ENDPOINT=http://localhost:4318
# RAMAN_OBSERVABILITY_CAPTURE_MESSAGE_CONTENT=false
# RAMAN_OBSERVABILITY_DISABLE_METRICS=false
# RAMAN_OBSERVABILITY_DISABLED_INSTRUMENTORS=mistral
# Local production-model debugging helpers.
# RAMAN_LOCAL_DEBUG_MODEL=gemma-4-31B-it
# RAMAN_LOCAL_DEBUG_LOG_LEVEL=DEBUG
# RAMAN_LOCAL_PORT=8000

# Eval gate. Offline pytest skips live evals unless set to 1.
# RAMAN_RUN_EVALS=1

# Web search tool. Required if any active agent spec lists "web_search".
# PARALLEL_API_KEY=

# Gateway persistence and DBOS workflow state.
# RAMAN_DB_PATH=.raman/raman.sqlite3
# DBOS_SYSTEM_DATABASE_URL=sqlite:///.raman/dbos.sqlite3
# RAMAN_PUBLIC_BASE_URL=https://example.ngrok-free.app

# Telegram interface. These env names are referenced by spec/telegram.toml.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,-1001234567890
# TELEGRAM_BOT_USERNAME=RamanBot
# TELEGRAM_API_BASE_URL=https://api.telegram.org
# GOBIND_TELEGRAM_BOT_TOKEN=
# GOBIND_TELEGRAM_WEBHOOK_SECRET=
# GOBIND_TELEGRAM_ALLOWED_CHAT_IDS=123456789,-1001234567890
# GOBIND_TELEGRAM_BOT_USERNAME=raniendu_gobind_bot
# GOBIND_TELEGRAM_API_BASE_URL=https://api.telegram.org
# LEO_TELEGRAM_BOT_TOKEN=
# LEO_TELEGRAM_WEBHOOK_SECRET=
# LEO_TELEGRAM_ALLOWED_CHAT_IDS=-1003368981977,920165401
# LEO_TELEGRAM_BOT_USERNAME=raniendu_leo_bot
# LEO_TELEGRAM_API_BASE_URL=https://api.telegram.org
