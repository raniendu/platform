# Copy to .env for direct app development. Do not commit populated secrets.

# Google ADK defaults to Gemini.
VIKRAM_MODEL=gemini-flash-latest
# GOOGLE_API_KEY=

# Agent selection.
# VIKRAM_AGENT=vikram
# VIKRAM_SPEC_ROOT=/abs/path/to/spec

# Eval gate. Offline pytest skips live evals unless set to 1.
# VIKRAM_RUN_EVALS=1

# Web search tool. Required if any active agent spec lists "web_search".
# VIKRAM_PARALLEL_API_KEY=
# PARALLEL_API_KEY=

# Gateway persistence, ADK sessions, and DBOS workflow state.
# VIKRAM_DB_PATH=.vikram/vikram.sqlite3
# VIKRAM_ADK_SESSION_DATABASE_URL=sqlite+aiosqlite:///.vikram/adk_sessions.sqlite3
# VIKRAM_DBOS_SYSTEM_DATABASE_URL=sqlite:///.vikram/dbos.sqlite3
# VIKRAM_PUBLIC_BASE_URL=https://example.ngrok-free.app

# Telegram interface.
# VIKRAM_TELEGRAM_BOT_TOKEN=
# VIKRAM_TELEGRAM_WEBHOOK_SECRET=
# VIKRAM_TELEGRAM_ALLOWED_CHAT_IDS=123456789,-1001234567890
# VIKRAM_TELEGRAM_API_BASE_URL=https://api.telegram.org
