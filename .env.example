COMPOSE_PROJECT_NAME=platform

# Shared Postgres superuser password for production consolidation.
# Local compose currently keeps separate development databases.
PLATFORM_POSTGRES_PASSWORD=platform_local

# Prefect local/prod settings
PREFECT_POSTGRES_PASSWORD=prefect_local
PREFECT_WORK_POOL_NAME=default-pool
PREFECT_WORK_POOL_TYPE=process
PREFECT_BASIC_AUTH_USER=admin
PREFECT_BASIC_AUTH_HASH=replace_with_caddy_hash
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
GEMINI_API_KEY=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Raman local/prod settings
# Local compose defaults to Ollama. Production should set
# RAMAN_MODEL_PROVIDER=digitalocean and RAMAN_DEV_MODEL=gemma-4-31B-it.
# Raman uses RAMAN_DEV_MODEL as the provider-specific model identifier in all
# environments, so local values name Ollama models and production values name
# DigitalOcean serverless inference models.
RAMAN_MODEL_PROVIDER=ollama
RAMAN_DEV_MODEL=gemma4:26b-mlx
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
RAMAN_AGENT=raman
RAMAN_LOG_LEVEL=INFO
RAMAN_OBSERVABILITY_ENABLED=false
RAMAN_OBSERVABILITY_SERVICE_NAME=raman
RAMAN_OTLP_ENDPOINT=http://jaeger:4318
RAMAN_OBSERVABILITY_CAPTURE_MESSAGE_CONTENT=false
RAMAN_OBSERVABILITY_DISABLE_METRICS=false
RAMAN_OBSERVABILITY_DISABLED_INSTRUMENTORS=mistral
RAMAN_CONTEXT_WINDOW_TOKENS=256000
RAMAN_CONTEXT_WARNING_RATIO=0.85
RAMAN_PUBLIC_BASE_URL=http://raman.localhost
# Optional for apps/raman/scripts/run-local-prod-debug.sh.
# RAMAN_LOCAL_DEBUG_MODEL=gemma-4-31B-it
# RAMAN_LOCAL_DEBUG_LOG_LEVEL=DEBUG
# RAMAN_LOCAL_PORT=8000
DO_INFERENCE_API_KEY=replace_with_do_inference_api_key
# Raman Telegram bot env names are referenced by apps/raman/spec/telegram.toml.
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=replace_with_telegram_webhook_secret
TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_BOT_USERNAME=replace_with_bot_username_without_at
GOBIND_TELEGRAM_BOT_TOKEN=replace_with_gobind_telegram_bot_token
GOBIND_TELEGRAM_WEBHOOK_SECRET=replace_with_gobind_telegram_webhook_secret
GOBIND_TELEGRAM_ALLOWED_CHAT_IDS=123456789
GOBIND_TELEGRAM_BOT_USERNAME=replace_with_gobind_bot_username_without_at
LEO_TELEGRAM_BOT_TOKEN=replace_with_leo_telegram_bot_token
LEO_TELEGRAM_WEBHOOK_SECRET=replace_with_leo_telegram_webhook_secret
LEO_TELEGRAM_ALLOWED_CHAT_IDS=-1003368981977,920165401
LEO_TELEGRAM_BOT_USERNAME=replace_with_leo_bot_username_without_at
PARALLEL_API_KEY=

# Airflow local/prod settings
AIRFLOW_UID=50000
AIRFLOW_POSTGRES_PASSWORD=airflow_local
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=local_airflow_secret_key_change_me
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Production-only settings
ACME_EMAIL=
DIGITALOCEAN_REGION=nyc3
DIGITALOCEAN_DROPLET_SIZE=s-1vcpu-2gb
DOTDEV_IMAGE=ghcr.io/raniendu/platform/dotdev:local
PREFECT_IMAGE=ghcr.io/raniendu/platform/prefect:local
AIRFLOW_IMAGE=ghcr.io/raniendu/platform/airflow:local
RAMAN_IMAGE=ghcr.io/raniendu/platform/raman:local
