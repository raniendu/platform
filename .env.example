COMPOSE_PROJECT_NAME=platform

# Shared Postgres superuser password for production consolidation.
# Local compose currently keeps separate development databases.
PLATFORM_POSTGRES_PASSWORD=platform_local

# Prefect local/prod settings
PREFECT_POSTGRES_PASSWORD=prefect_local
PREFECT_WORK_POOL_NAME=default-pool
PREFECT_WORK_POOL_TYPE=process
PREFECT_BASIC_AUTH_USER=admin
PREFECT_BASIC_AUTH_HASH=replace_with_caddy_hash
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
GEMINI_API_KEY=

# Paperclip local/prod settings
PAPERCLIP_POSTGRES_PASSWORD=paperclip_local
PAPERCLIP_BASIC_AUTH_USER=admin
# Local default password: paperclip_local
PAPERCLIP_BASIC_AUTH_HASH=$$2a$$14$$EXXQpS0ofvqBQH5LL9wrHuHBkSL3u0ycmQMc0JLVahU5IFR.A6C82
PAPERCLIP_BETTER_AUTH_SECRET=local_paperclip_better_auth_secret_change_me
PAPERCLIP_AGENT_JWT_SECRET=local_paperclip_agent_jwt_secret_change_me
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Airflow local/prod settings
AIRFLOW_UID=50000
AIRFLOW_POSTGRES_PASSWORD=airflow_local
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=local_airflow_secret_key_change_me
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Production-only settings
ACME_EMAIL=
DIGITALOCEAN_REGION=nyc3
DIGITALOCEAN_DROPLET_SIZE=s-1vcpu-2gb
DOTDEV_IMAGE=ghcr.io/raniendu/platform/dotdev:local
PREFECT_IMAGE=ghcr.io/raniendu/platform/prefect:local
AIRFLOW_IMAGE=ghcr.io/raniendu/platform/airflow:local
PAPERCLIP_IMAGE=ghcr.io/raniendu/platform/paperclip:local
