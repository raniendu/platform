# ============================================================================
# Airflow Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# Requirements: 8.1, 8.2

# ============================================================================
# SECURITY & ENCRYPTION
# ============================================================================

# Fernet Key - Used by Airflow to encrypt sensitive data (connections, variables)
# Generate using: python scripts/generate-fernet-key.py
# REQUIRED for production
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here

# Webserver Secret Key - Used for session management and CSRF protection
# Generate using: python -c "import secrets; print(secrets.token_urlsafe(32))"
# REQUIRED for production
AIRFLOW__WEBSERVER__SECRET_KEY=your_secret_key_here

# ============================================================================
# ADMIN USER CREDENTIALS
# ============================================================================

# Initial admin username for Airflow webserver
# This user will be created on first deployment with Admin role
# Requirements: 7.1, 7.2
AIRFLOW_ADMIN_USER=admin

# Initial admin password for Airflow webserver
# Use a strong password for production deployments
# Requirements: 7.1, 7.2
AIRFLOW_ADMIN_PASSWORD=your_secure_password_here

# Optional: Admin user email (defaults to admin@example.com)
# AIRFLOW_ADMIN_EMAIL=admin@example.com

# Optional: Admin user first name (defaults to Admin)
# AIRFLOW_ADMIN_FIRSTNAME=Admin

# Optional: Admin user last name (defaults to User)
# AIRFLOW_ADMIN_LASTNAME=User

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL password for Airflow metadata database
# Used in production docker-compose.yml
# REQUIRED for production
POSTGRES_PASSWORD=your_postgres_password_here

# ============================================================================
# DOMAIN CONFIGURATION
# ============================================================================

# Domain name for the Airflow instance
# Used by nginx and certbot for SSL certificate generation
# Requirements: 6.1
DOMAIN=flow.raniendu.dev

# ============================================================================
# SYSTEM CONFIGURATION
# ============================================================================

# User ID for running Airflow processes
# Default: 50000 (matches official Airflow Docker image)
# Change if you need to match your host system's user ID
AIRFLOW_UID=50000

# ============================================================================
# NOTES
# ============================================================================
# 
# Local Development:
# - For local development, you can use simpler values
# - The docker-compose.local.yml uses SQLite and has authentication disabled
# - Run: docker-compose -f docker-compose.local.yml up
#
# Production Deployment:
# - All values marked REQUIRED must be set with secure values
# - Never commit the actual .env file to version control
# - Store production secrets in GitHub Secrets for CI/CD
# - Run: docker-compose up -d
#
# GitHub Secrets Required for CI/CD:
# - DO_SSH_PRIVATE_KEY: SSH private key for Digital Ocean Droplet access
# - DO_HOST: IP address of the Digital Ocean Droplet
# - AIRFLOW_ADMIN_USER: Admin username
# - AIRFLOW_ADMIN_PASSWORD: Admin password
# - AIRFLOW__CORE__FERNET_KEY: Fernet encryption key
# - AIRFLOW__WEBSERVER__SECRET_KEY: Webserver secret key
# - POSTGRES_PASSWORD: PostgreSQL password
#
# ============================================================================
