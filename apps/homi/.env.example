# Copy to .env for direct app development. Do not commit populated secrets.

# Strands defaults to Amazon Bedrock. Configure AWS credentials with the
# standard AWS_* environment variables or AWS_BEARER_TOKEN_BEDROCK.
HOMI_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
HOMI_AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_BEARER_TOKEN_BEDROCK=

# Agent selection.
# HOMI_AGENT=homi
# HOMI_SPEC_ROOT=/abs/path/to/spec

# Eval gate. Offline pytest skips live evals unless set to 1.
# HOMI_RUN_EVALS=1

# Web search tool. Required if any active agent spec lists "web_search".
# HOMI_PARALLEL_API_KEY=
# PARALLEL_API_KEY=

# Gateway persistence and DBOS workflow state.
# HOMI_DB_PATH=.homi/homi.sqlite3
# HOMI_DBOS_SYSTEM_DATABASE_URL=sqlite:///.homi/dbos.sqlite3
# HOMI_PUBLIC_BASE_URL=https://example.ngrok-free.app

# Telegram interface.
# HOMI_TELEGRAM_BOT_TOKEN=
# HOMI_TELEGRAM_WEBHOOK_SECRET=
# HOMI_TELEGRAM_ALLOWED_CHAT_IDS=123456789,-1001234567890
# HOMI_TELEGRAM_API_BASE_URL=https://api.telegram.org
